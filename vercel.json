{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/match.js": {
      "runtime": "nodejs18.x"
    },
    "api/generate-email.js": {
      "runtime": "nodejs18.x"
    }
  }
}
